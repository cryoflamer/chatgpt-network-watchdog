{
  "manifest_version": 3,
  "name": "ChatGPT Network Watchdog",
  "version": "0.1.0",
  "description": "Detects ChatGPT response completion through backend network requests and monitors frozen tabs.",
  "permissions": [
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ChatGPT Network Watchdog"
  }
}
